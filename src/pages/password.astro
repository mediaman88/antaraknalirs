---
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const entered = form.get('password')?.toString() ?? '';
  const correct = import.meta.env.SITE_PASSWORD;

  if (entered === correct) {
    Astro.cookies.set('auth', 'ok', {
      path: '/',
      maxAge: 60 * 60 * 24 * 7, // 7 days
      httpOnly: true,
      sameSite: 'lax',
    });
    return Astro.redirect('/');
  }

  return Astro.redirect('/password?error=1');
}

const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Enter Password</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f0eb;
      font-family: Georgia, serif;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 2.5rem 2rem;
      width: min(360px, 90vw);
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      text-align: center;
    }
    h1 { font-size: 1.4rem; margin-bottom: 0.5rem; color: #2c2c2c; }
    p { color: #777; font-size: 0.9rem; margin-bottom: 1.5rem; }
    input[type="password"] {
      width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #ddd; border-radius: 8px;
      font-size: 1rem; margin-bottom: 1rem; outline: none; transition: border-color 0.2s;
    }
    input[type="password"]:focus { border-color: #888; }
    button {
      width: 100%; padding: 0.75rem; background: #2c2c2c; color: white; border: none;
      border-radius: 8px; font-size: 1rem; cursor: pointer; font-family: inherit;
    }
    button:hover { background: #444; }
    .error { color: #c0392b; font-size: 0.85rem; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>The Grand Journey</h1>
    <p>Enter the password to continue</p>
    <form method="POST">
      {error && <p class="error">Incorrect password, please try again.</p>}
      <input type="password" name="password" placeholder="Password" autofocus required />
      <button type="submit">Enter</button>
    </form>
  </div>
</body>
</html>
