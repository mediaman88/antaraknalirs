---
import Base from '../../layouts/Base.astro';
import DayContent from '../../components/DayContent.astro';
import trip from '../../data/trip.json';

const days = (trip as any).days;
const { slug } = Astro.params;
const i = days.findIndex((d: any) => d.slug === slug);
if (i === -1) return Astro.redirect('/');
const day = days[i];
const prev = days[i - 1] ?? null;
const next = days[i + 1] ?? null;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (p: string) => `${base}${p}`;
const strip = (s: string) => (s || '').replace(/&[a-z]+;/g, ' ').replace(/<[^>]+>/g, '');

const albumModules = import.meta.glob('../../data/albums/*.json', { eager: true });
const hasAlbum = Object.keys(albumModules).some((p) => p.endsWith(`/${day.slug}.json`));
---
<Base title={`${strip(day.title)} · Trip`} back={true} current={day.slug}>
  <DayContent day={day} />
  {hasAlbum && (
    <div class="dwrap">
      <a class="album-link" href={href(`/day/${day.slug}/album`)}>View Photo Album &rarr;</a>
    </div>
  )}
  <div class="daynav">
    {prev
      ? <a class="prev" href={href(`/day/${prev.slug}`)}><div class="dn-l">&larr; Previous</div><div class="dn-t" set:html={prev.title} /></a>
      : <a class="prev disabled"><div class="dn-l">&larr; Previous</div><div class="dn-t">&mdash;</div></a>}
    {next
      ? <a class="next" href={href(`/day/${next.slug}`)}><div class="dn-l">Next &rarr;</div><div class="dn-t" set:html={next.title} /></a>
      : <a class="next" href={href('/day/homeward')}><div class="dn-l">Next &rarr;</div><div class="dn-t">Homeward Bound</div></a>}
  </div>
</Base>
